{
  "name": "@ricky9w/sing-box-schema",
  "version": "1.13.0",
  "description": "A comprehensive Zod & JSON schema for sing-box configuration files, built with TypeScript. Fork of @black-duty/sing-box-schema used by sing-manager.",
  "keywords": [
    "sing-box",
    "schema",
    "zod",
    "typescript",
    "bun",
    "configuration"
  ],
  "homepage": "https://github.com/ricky9w/sing-box-schema#readme",
  "bugs": {
    "url": "https://github.com/ricky9w/sing-box-schema/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricky9w/sing-box-schema.git"
  },
  "author": "ricky9w",
  "license": "MIT",
  "files": [
    "./dist",
    "schema.json",
    "schema.zh.json"
  ],
  "scripts": {
    "build": "tsdown && bun run generate",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write",
    "generate": "bun run scripts/gen-json-schema.ts",
    "check-version": "bun run scripts/check-version.ts",
    "prepublishOnly": "bun run build"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json",
    "./schema.json": "./schema.json",
    "./schema.zh.json": "./schema.zh.json"
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@tsconfig/bun": "^1.0.8",
    "@types/bun": "^1.2.20",
    "tsdown": "^0.14.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./package.json": "./package.json",
      "./schema.json": "./schema.json",
      "./schema.zh.json": "./schema.zh.json"
    }
  },
  "readme": "README.md",
  "dependencies": {
    "zod": "^4.0.17"
  }
}